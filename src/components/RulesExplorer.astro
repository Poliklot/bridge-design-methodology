  'variation.breakpoint-content-drift': 'Содержимое меняется только из-за ширины',
  'variation.theme-content-drift': 'Тема оформления меняет содержимое',
  'variation.axis-overload': 'Одна ось скрывает несколько причин вариативности',
  'adapter.unsupported-feature': 'Адаптер не поддерживает использованную функцию',
};

const principleRu: Record<string, string> = {
  Breakpoints: 'Адаптивы',
  Roles: 'Назначение',
  Identity: 'Идентификаторы',
  Dependencies: 'Связи',
  Geometry: 'Геометрия',
  Exceptions: 'Исключения',
};

const severityRu: Record<string, string> = {
  error: 'Ошибка',
  warning: 'Предупреждение',
  info: 'Справка',
};

const automationRu: Record<string, string> = {
  automatic: 'Автоматически',
  heuristic: 'Эвристически',
  manual: 'Вручную',
};

const humanize = (id: string) => {
  const text = id.split('.').at(-1)?.replaceAll('-', ' ') || id;
  return text.charAt(0).toUpperCase() + text.slice(1);
};

const copy = locale === 'ru'
  ? {
      eyebrow: 'Машиночитаемый справочник',
      title: 'Каталог правил валидатора',
      lead: `${catalog.rules.length} правил из validator/rules.json. Фильтруйте по идентификатору, принципу, серьёзности и способу проверки.`,
      search: 'Поиск по правилу',
      searchPlaceholder: 'Например: modal, breakpoint, text…',
      severityLabel: 'Серьёзность',
      automationLabel: 'Способ проверки',
      severity: 'Любая серьёзность',
      automation: 'Любая проверка',
      results: 'правил показано',
      canonical: 'Каноническое описание на английском',
      fix: 'Как исправить',
      empty: 'Правила с такими условиями не найдены.',
    }
  : {
      eyebrow: 'Machine-readable reference',
      title: 'Validator rule catalog',
      lead: `${catalog.rules.length} rules from validator/rules.json. Filter by ID, principle, severity, and automation level.`,
      search: 'Search rules',
      searchPlaceholder: 'For example: modal, breakpoint, text…',
      severityLabel: 'Severity',
      automationLabel: 'Automation',
      severity: 'Any severity',
      automation: 'Any automation',
      results: 'rules shown',
      canonical: 'Description',
      fix: 'How to fix',
      empty: 'No rules match these filters.',
    };
---

<section class="rules-explorer" data-rules-explorer>
  <header>
    <p class="bridge-eyebrow">{copy.eyebrow}</p>
    <h1>{copy.title}</h1>
    <p>{copy.lead}</p>
  </header>

  <div class="rules-controls">
    <label class="rules-search">
      <span>{copy.search}</span>
      <input type="search" placeholder={copy.searchPlaceholder} data-rule-search />
    </label>
    <label>
      <span class="sr-only">{copy.severityLabel}</span>
      <select data-rule-severity>
        <option value="">{copy.severity}</option>
        {catalog.severityLevels.map((level) => <option value={level}>{locale === 'ru' ? severityRu[level] : level}</option>)}
      </select>
    </label>
    <label>
      <span class="sr-only">{copy.automationLabel}</span>
      <select data-rule-automation>
        <option value="">{copy.automation}</option>
        {catalog.automationLevels.map((level) => <option value={level}>{locale === 'ru' ? automationRu[level] : level}</option>)}
      </select>
    </label>
  </div>

  <div class="rules-meta" aria-live="polite"><strong data-rule-count>{catalog.rules.length}</strong> {copy.results}</div>

  <div class="rules-list">
    {catalog.rules.map((rule) => {
      const title = locale === 'ru' ? (ruTitles[rule.id] || humanize(rule.id)) : humanize(rule.id);
      const searchable = [rule.id, title, rule.principle, rule.severity, rule.automation, rule.description, rule.fix].join(' ').toLowerCase();
      return (
        <article
          class={`rule-card rule-${rule.severity}`}
          data-rule
          data-severity={rule.severity}
          data-automation={rule.automation}
          data-search={searchable}
        >
          <div class="rule-card-head">
            <div>
              <code>{rule.id}</code>
              <h2>{title}</h2>
            </div>
            <div class="rule-badges">
              <span>{locale === 'ru' ? (principleRu[rule.principle] || rule.principle) : rule.principle}</span>
              <span>{locale === 'ru' ? severityRu[rule.severity] : rule.severity}</span>
              <span>{locale === 'ru' ? automationRu[rule.automation] : rule.automation}</span>
            </div>
          </div>
          {locale === 'en' ? (
            <><p>{rule.description}</p><div class="rule-fix"><strong>{copy.fix}</strong><p>{rule.fix}</p></div></>
          ) : (
            <details>
              <summary>{copy.canonical}</summary>
              <p lang="en">{rule.description}</p>
              <div class="rule-fix" lang="en"><strong>{copy.fix}</strong><p>{rule.fix}</p></div>
            </details>
          )}
        </article>
      );
    })}
  </div>

  <p class="rules-empty" data-rules-empty hidden>{copy.empty}</p>
</section>

<script>
  const initializeRuleExplorer = (root: Element) => {
    if (!(root instanceof HTMLElement) || root.dataset.ready === 'true') return;
    root.dataset.ready = 'true';
    const search = root.querySelector('[data-rule-search]');
    const severity = root.querySelector('[data-rule-severity]');
    const automation = root.querySelector('[data-rule-automation]');
    const cards = [...root.querySelectorAll('[data-rule]')];
    const count = root.querySelector('[data-rule-count]');
    const empty = root.querySelector('[data-rules-empty]');

    const filter = () => {
      const query = search instanceof HTMLInputElement ? search.value.trim().toLowerCase() : '';
      const severityValue = severity instanceof HTMLSelectElement ? severity.value : '';
      const automationValue = automation instanceof HTMLSelectElement ? automation.value : '';
      let visible = 0;

      for (const card of cards) {
        if (!(card instanceof HTMLElement)) continue;
        const matches = (!query || card.dataset.search?.includes(query))
          && (!severityValue || card.dataset.severity === severityValue)
          && (!automationValue || card.dataset.automation === automationValue);
        card.hidden = !matches;
        if (matches) visible += 1;
      }

      if (count) count.textContent = String(visible);
      if (empty instanceof HTMLElement) empty.hidden = visible !== 0;
    };

    search?.addEventListener('input', filter);
    severity?.addEventListener('change', filter);
    automation?.addEventListener('change', filter);
  };

  for (const root of document.querySelectorAll('[data-rules-explorer]')) initializeRuleExplorer(root);
</script>
