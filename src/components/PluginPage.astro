---
import PluginMediaShowcase from './PluginMediaShowcase.astro';

interface Props {
  locale: 'ru' | 'en';
}

const { locale } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/u, '');
const url = (path: string) => `${base}/${locale}/${path.replace(/^\//u, '')}`;
const pluginUrl = 'https://www.figma.com/community/plugin/1654485530503673254/bridge';
const supportUrl = 'https://github.com/Poliklot/bridge-figma-assistant/issues';

const copy = locale === 'ru'
  ? {
      eyebrow: 'Официальный плагин для Figma',
      title: 'Проверьте макет прямо в Figma.',
      lead: 'Помечайте страницы, адаптивы, секции и действия, переходите по карте файла и запускайте Preflight — без ручного переноса данных в отдельный чеклист.',
      open: 'Открыть в Figma',
      start: 'Начать за 5 шагов',
      facts: ['Работает локально', 'Не требует аккаунта', 'Не имеет доступа к сети', 'Детерминированные проверки'],
      previewAlt: 'Отчёт Page Check в плагине BRIDGE для Figma',
      previewCaption: 'Реальный интерфейс · Figma Community',
      demoEyebrow: 'Демонстрация продукта',
      demoTitle: 'От выбранного слоя до готового Page Check — за 30 секунд.',
      demoText: 'Объявите адаптивы, добавьте намерение, свяжите цель и откройте точное правило — не покидая текущий Figma-файл.',
      demoLabel: 'Видео-демонстрация плагина BRIDGE. Интерфейс и озвучка на английском, доступны русские субтитры.',
      demoCaption: '00:30 · интерфейс на английском · русские и английские субтитры',
      transcriptLabel: 'Что происходит за 30 секунд',
      demoSteps: [
        ['0:00', 'Корневые адаптивы получают общую identity страницы.'],
        ['0:04', 'Выбранный слой получает действие без ручного синтаксиса.'],
        ['0:08', 'Готовая цель вставляется без повторного набора ID.'],
        ['0:12', 'Карта файла открывает нужный объект.'],
        ['0:15', 'Page Check находит разрывы, черновики и предупреждения.'],
        ['0:20', 'Вопрос ведёт к точному каноническому правилу.'],
        ['0:25', 'Локальный и открытый цикл замыкает дизайн и код.'],
      ],
      workflowEyebrow: 'Рабочий процесс',
      workflowTitle: 'Три действия внутри текущего Figma-файла.',
      workflow: [
        ['01', 'Объявите', 'Выберите значимый слой и добавьте только тот смысл, которого нет в нативной структуре Figma.', '[action=modal:contact-modal]'],
        ['02', 'Свяжите', 'Используйте карту файла и существующие цели, чтобы страница, действие и адаптив читались однозначно.', 'contact-button → contact-modal'],
        ['03', 'Проверьте', 'Запустите Page Check и исправьте вопросы до передачи макета разработчику.', 'issue → layer → rule → fix'],
      ],
      privacyTitle: 'Макет остаётся в вашем файле.',
      privacyText: 'BRIDGE работает локально в текущем документе Figma, не требует отдельной регистрации и не отправляет содержимое файла по сети.',
      support: 'Сообщить о проблеме',
      methodology: 'Открыть методологию',
    }
  : {
      eyebrow: 'Official Figma plugin',
      title: 'Review the design directly in Figma.',
      lead: 'Tag pages, breakpoints, sections, and actions, navigate the file map, and run Preflight — without moving design data into a separate browser checklist.',
      open: 'Open in Figma',
      start: 'Start in 5 steps',
      facts: ['Runs locally', 'No account required', 'No network access', 'Deterministic checks'],
      previewAlt: 'BRIDGE Page Check report in Figma',
      previewCaption: 'Real product interface · Figma Community',
      demoEyebrow: 'Product demo',
      demoTitle: 'From the selected layer to a complete Page Check in 30 seconds.',
      demoText: 'Declare breakpoints, add intent, connect a target, and open the exact rule — without leaving the current Figma file.',
      demoLabel: 'BRIDGE plugin video demo with English interface and voiceover. English captions are available.',
      demoCaption: '00:30 · English interface · English and Russian captions',
      transcriptLabel: 'What happens in 30 seconds',
      demoSteps: [
        ['0:00', 'Responsive roots receive one shared page identity.'],
        ['0:04', 'The selected layer receives an action without handwritten syntax.'],
        ['0:08', 'A declared target is pasted without retyping its ID.'],
        ['0:12', 'The file map opens the exact object.'],
        ['0:15', 'Page Check finds gaps, drafts, and warnings.'],
        ['0:20', 'The issue opens the exact canonical rule.'],
        ['0:25', 'A local, open loop keeps design and code aligned.'],
      ],
      workflowEyebrow: 'Workflow',
      workflowTitle: 'Three actions inside the current Figma file.',
      workflow: [
        ['01', 'Declare', 'Select a meaningful layer and add only the intent that is missing from native Figma structure.', '[action=modal:contact-modal]'],
        ['02', 'Connect', 'Use the file map and existing targets so the page, action, and breakpoint are unambiguous.', 'contact-button → contact-modal'],
        ['03', 'Review', 'Run Page Check and resolve questions before handing the design to implementation.', 'issue → layer → rule → fix'],
      ],
      privacyTitle: 'The design stays in your file.',
      privacyText: 'BRIDGE runs locally in the current Figma document, requires no separate account, and does not send file contents over the network.',
      support: 'Report an issue',
      methodology: 'Open the methodology',
    };
---

<div class="plugin-page not-content">
  <section class="plugin-hero" aria-labelledby="plugin-title">
    <div class="plugin-hero-copy">
      <p class="bridge-eyebrow">{copy.eyebrow}</p>
      <div class="plugin-identity">
        <img src={`${base}/assets/plugin/bridge-plugin-icon.png`} width="52" height="52" alt="" />
        <span>BRIDGE <small>for Figma</small></span>
      </div>
      <h1 id="plugin-title">{copy.title}</h1>
      <p class="plugin-lead">{copy.lead}</p>
      <div class="bridge-actions">
        <a class="bridge-button bridge-button-primary" href={pluginUrl} target="_blank" rel="noopener noreferrer">
          {copy.open}<span aria-hidden="true"> ↗</span>
        </a>
        <a class="bridge-button bridge-button-secondary" href={url('start/designer-quick-start/')}>{copy.start}</a>
      </div>
      <ul class="plugin-facts" aria-label={locale === 'ru' ? 'Приватность плагина' : 'Plugin privacy'}>
        {copy.facts.map((fact) => <li><span aria-hidden="true"></span>{fact}</li>)}
      </ul>
    </div>

    <figure class="plugin-preview">
      <picture>
        <source media="(max-width: 50rem)" srcset={`${base}/assets/plugin/showcase/ui/preflight.png`} width="680" height="760" />
        <img src={`${base}/assets/plugin/showcase/01-preflight.png`} width="1920" height="1080" alt={copy.previewAlt} loading="eager" />
      </picture>
      <figcaption>{copy.previewCaption}</figcaption>
    </figure>
  </section>

  <section class="bridge-section plugin-demo" id="plugin-demo" aria-labelledby="plugin-demo-title">
    <header class="plugin-demo-heading">
      <p class="bridge-eyebrow">{copy.demoEyebrow}</p>
      <div><h2 id="plugin-demo-title">{copy.demoTitle}</h2><p>{copy.demoText}</p></div>
    </header>
    <figure class="plugin-demo-frame">
      <video
        controls
        playsinline
        preload="metadata"
        poster={`${base}/assets/plugin/showcase/01-preflight.png`}
        aria-label={copy.demoLabel}
      >
        <source src={`${base}/assets/plugin/showcase/bridge-product-demo.mp4`} type="video/mp4" />
        <track kind="captions" srclang="ru" label="Русские" src={`${base}/assets/plugin/showcase/bridge-product-demo.ru.vtt`} default={locale === 'ru'} />
        <track kind="captions" srclang="en" label="English" src={`${base}/assets/plugin/showcase/bridge-product-demo.en.vtt`} default={locale === 'en'} />
      </video>
      <figcaption>{copy.demoCaption}</figcaption>
    </figure>
    <details class="plugin-demo-transcript">
      <summary>{copy.transcriptLabel}</summary>
      <ol>
        {copy.demoSteps.map(([time, text]) => <li><time>{time}</time><span>{text}</span></li>)}
      </ol>
    </details>
  </section>

  <PluginMediaShowcase locale={locale} />

  <section class="bridge-section plugin-workflow" aria-labelledby="plugin-workflow-title">
    <div class="plugin-section-heading">
      <p class="bridge-eyebrow">{copy.workflowEyebrow}</p>
      <h2 id="plugin-workflow-title">{copy.workflowTitle}</h2>
    </div>
    <ol>
      {copy.workflow.map(([number, title, description, sample]) => (
        <li>
          <span>{number}</span>
          <div><h3>{title}</h3><p>{description}</p><code>{sample}</code></div>
        </li>
      ))}
    </ol>
  </section>

  <section class="plugin-privacy" aria-labelledby="plugin-privacy-title">
    <div>
      <span class="plugin-privacy-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24"><path d="M7.5 10V7.5a4.5 4.5 0 0 1 9 0V10M6 10h12v10H6z"></path></svg>
      </span>
      <div><h2 id="plugin-privacy-title">{copy.privacyTitle}</h2><p>{copy.privacyText}</p></div>
    </div>
    <div class="plugin-privacy-actions">
      <a href={supportUrl} target="_blank" rel="noopener noreferrer">{copy.support}<span aria-hidden="true"> ↗</span></a>
      <a href={url('reference/transfer-contract/')}>{copy.methodology}<span aria-hidden="true"> →</span></a>
    </div>
  </section>
</div>
