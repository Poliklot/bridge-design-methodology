---
interface Props {
  locale: 'ru' | 'en';
}

const { locale } = Astro.props;
const pluginUrl = 'https://www.figma.com/community/plugin/1654485530503673254/bridge';
const sourceUrl = 'https://github.com/Poliklot/bridge-figma-assistant';

const copy = locale === 'ru'
  ? {
      eyebrow: 'Инструмент методологии',
      title: 'Проверяйте готовность макета прямо в Figma.',
      lead: 'Плагин добавляет теги BRIDGE в имена слоёв, собирает карту файла и проверяет страницы, адаптивы, действия и цели перед передачей в разработку.',
      open: 'Figma plugin BRIDGE',
      capabilitiesLabel: 'Что делает плагин',
      capabilities: [
        ['Теги', 'Добавляет page, breakpoint, action и target без ручного набора синтаксиса.'],
        ['Карта', 'Собирает страницы, цели и черновики в понятную структуру файла.'],
        ['Проверка', 'Находит разрывы и открывает нужный слой и правило.'],
      ],
      trust: 'Локально в Figma · без аккаунта BRIDGE · без сетевого доступа',
      source: 'Исходный код',
      newTab: 'откроется в новой вкладке',
    }
  : {
      eyebrow: 'Methodology tool',
      title: 'Review design readiness directly in Figma.',
      lead: 'The plugin adds BRIDGE tags to layer names, maps the file, and checks pages, breakpoints, actions, and targets before implementation handoff.',
      open: 'Figma plugin BRIDGE',
      capabilitiesLabel: 'What the plugin does',
      capabilities: [
        ['Tags', 'Adds page, breakpoint, action, and target tags without handwritten syntax.'],
        ['Map', 'Collects pages, targets, and drafts into a clear file structure.'],
        ['Check', 'Finds gaps and opens the relevant layer and rule.'],
      ],
      trust: 'Local in Figma · no BRIDGE account · no network access',
      source: 'Source code',
      newTab: 'opens in a new tab',
    };
---

<div class="plugin-page not-content">
  <section class="plugin-brief" aria-labelledby="plugin-title">
    <div class="plugin-brief-copy">
      <p class="bridge-eyebrow">{copy.eyebrow}</p>
      <h1 id="plugin-title">{copy.title}</h1>
      <p class="plugin-brief-lead">{copy.lead}</p>
      <a
        class="plugin-brief-cta bridge-button bridge-button-primary"
        href={pluginUrl}
        target="_blank"
        rel="noopener noreferrer"
      >
        {copy.open}<span aria-hidden="true"> ↗</span><span class="sr-only"> — {copy.newTab}</span>
      </a>
    </div>

    <ul class="plugin-capabilities" aria-label={copy.capabilitiesLabel}>
      {copy.capabilities.map(([title, description], index) => (
        <li>
          <span aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
          <strong>{title}</strong>
          <p>{description}</p>
        </li>
      ))}
    </ul>

    <footer class="plugin-brief-meta">
      <p>{copy.trust}</p>
      <a href={sourceUrl} target="_blank" rel="noopener noreferrer">
        {copy.source}<span aria-hidden="true"> ↗</span><span class="sr-only"> — {copy.newTab}</span>
      </a>
    </footer>
  </section>
</div>
