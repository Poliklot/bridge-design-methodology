---
interface Props {
  locale: 'ru' | 'en';
}

const { locale } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/u, '');
const url = (path: string) => `${base}/${locale}/${path.replace(/^\//u, '')}`;

const copy = locale === 'ru'
  ? {
      eyebrow: 'Открытая методология передачи макетов',
      title: 'Передайте макет так, чтобы его не пришлось объяснять.',
      lead: 'BRIDGE фиксирует структуру, адаптивы, действия и исключения до начала разработки — прямо там, где принимаются дизайнерские решения.',
      primary: 'Подготовить первый макет',
      secondary: 'Посмотреть пример',
      promise: ['15 минут до первого результата', 'Без привязки к платформе', 'Проверяемый контракт'],
      inspectorTitle: 'Один макет. Два уровня ясности.',
      before: 'До BRIDGE',
      after: 'После BRIDGE',
      beforeNote: 'Связи приходится восстанавливать по внешнему виду.',
      afterNote: 'Страница, адаптив и действие читаются из структуры.',
      treeBeforeDesktop: 'Главная — финал',
      treeBeforeMobile: 'Главная — мобильная',
      treePage: 'Главная',
      treeSection: 'Первый экран',
      pathsEyebrow: 'Не читайте всё подряд',
      pathsTitle: 'Начните со своей задачи',
      paths: [
        ['Дизайнер', 'Подготовьте первый файл по пяти шагам.', 'Открыть быстрый старт', 'start/designer-quick-start/'],
        ['Ревьюер', 'Проверьте готовность макета перед передачей.', 'Запустить проверку', 'check/'],
        ['Разработчик инструмента', 'Используйте теги, контракт и каталог правил.', 'Открыть справочник', 'reference/transfer-contract/'],
      ],
      methodEyebrow: 'Как это работает',
      methodTitle: 'Сначала структура. Затем смысл. После — проверка.',
      method: [
        ['01', 'Соберите техническую правду', 'Фреймы, Auto Layout, компоненты и геометрия остаются в Figma.'],
        ['02', 'Добавьте недостающий смысл', 'Теги описывают страницу, действие, цель, декор, экспорт и исключения.'],
        ['03', 'Проверьте без автора', 'Другой человек должен понять файл без созвона и дополнительных пояснений.'],
      ],
      principlesEyebrow: 'Контракт BRIDGE',
      principlesTitle: 'Шесть вопросов, на которые отвечает готовый макет',
      principles: [
        ['B', 'Адаптивы', 'Какие ширины и состояния подготовлены?'],
        ['R', 'Назначение', 'Для чего нужен каждый значимый слой?'],
        ['I', 'Идентификаторы', 'Как узнать один элемент на разных ширинах?'],
        ['D', 'Связи', 'Куда ведут ссылки и что делают кнопки?'],
        ['G', 'Геометрия', 'Можно ли воспроизвести размеры и отступы?'],
        ['E', 'Исключения', 'Какие отклонения сделаны намеренно?'],
      ],
      finalTitle: 'Проверьте реальный макет, а не идеальный пример.',
      finalText: 'Интерактивный чеклист сохранит прогресс в браузере и подготовит отчёт по оставшимся вопросам.',
      finalAction: 'Проверить макет',
    }
  : {
      eyebrow: 'Open design handoff methodology',
      title: 'Hand off a design that does not need to be decoded.',
      lead: 'BRIDGE makes structure, breakpoints, actions, and exceptions explicit before implementation — at the point where design decisions are made.',
      primary: 'Prepare your first design',
      secondary: 'See an example',
      promise: ['15 minutes to a first result', 'Target-independent', 'Machine-checkable contract'],
      inspectorTitle: 'One design. Two levels of clarity.',
      before: 'Before BRIDGE',
      after: 'After BRIDGE',
      beforeNote: 'Relationships must be inferred from appearance.',
      afterNote: 'Page, breakpoint, and action are explicit in the tree.',
      treeBeforeDesktop: 'Home — final',
      treeBeforeMobile: 'Home — mobile',
      treePage: 'Home',
      treeSection: 'Hero',
      pathsEyebrow: 'Do not read everything',
      pathsTitle: 'Start with the job in front of you',
      paths: [
        ['Designer', 'Prepare a first file in five practical steps.', 'Open quick start', 'start/designer-quick-start/'],
        ['Reviewer', 'Check whether a design is ready for implementation.', 'Run preflight', 'check/'],
        ['Tool builder', 'Use the tag grammar, contract, and rule catalog.', 'Open reference', 'reference/transfer-contract/'],
      ],
      methodEyebrow: 'How it works',
      methodTitle: 'Structure first. Intent second. Validation last.',
      method: [
        ['01', 'Build technical truth', 'Frames, Auto Layout, components, and geometry remain native Figma data.'],
        ['02', 'Declare missing intent', 'Tags describe pages, actions, targets, decor, assets, and exceptions.'],
        ['03', 'Review without the author', 'Someone else should understand the file without a call or private context.'],
      ],
      principlesEyebrow: 'The BRIDGE contract',
      principlesTitle: 'Six questions a transferable design can answer',
      principles: [
        ['B', 'Breakpoints', 'Which widths and responsive states exist?'],
        ['R', 'Roles', 'What is every important layer for?'],
        ['I', 'Identity', 'How is one element recognized across variants?'],
        ['D', 'Dependencies', 'Where do links and actions lead?'],
        ['G', 'Geometry', 'Can size, spacing, and text metrics be reproduced?'],
        ['E', 'Exceptions', 'Which deviations are intentional?'],
      ],
      finalTitle: 'Review a real design, not an ideal example.',
      finalText: 'The interactive checklist stores progress locally and prepares a report of unresolved questions.',
      finalAction: 'Check a design',
    };
---

<div class="bridge-home">
  <section class="bridge-hero" aria-labelledby="bridge-home-title">
    <div class="bridge-hero-copy">
      <p class="bridge-eyebrow">{copy.eyebrow}</p>
      <h1 id="bridge-home-title">{copy.title}</h1>
      <p class="bridge-lead">{copy.lead}</p>
      <div class="bridge-actions">
        <a class="bridge-button bridge-button-primary" href={url('start/designer-quick-start/')}>{copy.primary}</a>
        <a class="bridge-button bridge-button-secondary" href={url('examples/')}>{copy.secondary}</a>
      </div>
      <ul class="bridge-promises" aria-label={locale === 'ru' ? 'Преимущества' : 'Highlights'}>
        {copy.promise.map((item) => <li>{item}</li>)}
      </ul>
    </div>

    <div class="bridge-inspector" data-inspector>
      <div class="bridge-inspector-head">
        <p>{copy.inspectorTitle}</p>
        <div class="bridge-inspector-tabs" role="group" aria-label={copy.inspectorTitle}>
          <button type="button" data-inspector-mode="before" aria-pressed="false">{copy.before}</button>
          <button type="button" data-inspector-mode="after" aria-pressed="true">{copy.after}</button>
        </div>
      </div>
      <div class="bridge-tree bridge-tree-before" data-inspector-panel="before">
        <p class="bridge-tree-label">{copy.before}</p>
        <pre><code><span>{copy.treeBeforeDesktop}</span>
  <i>Frame 42</i>
    Group 18
      Heading
      Text
    Button

<span>{copy.treeBeforeMobile}</span>
  Group 91
    Title mobile
    Button copy</code></pre>
        <p>{copy.beforeNote}</p>
      </div>
      <div class="bridge-tree bridge-tree-after is-active" data-inspector-panel="after">
        <p class="bridge-tree-label">{copy.after}</p>
        <pre><code><span>{copy.treePage} [page=home]</span>
  [bp=1440] [view=default]
  <i>{copy.treeSection} [section=home-hero]</i>
    hero-copy
      hero-title
    contact-button
      <b>[action=modal:contact-modal]</b>

<span>{copy.treePage} [page=home]</span>
  [bp=375] [view=default]</code></pre>
        <p>{copy.afterNote}</p>
      </div>
      <ol class="bridge-module-rail" aria-label="BRIDGE">
        {copy.principles.map(([letter, label]) => <li title={label}><b>{letter}</b><span>{label}</span></li>)}
      </ol>
    </div>
  </section>

  <section class="bridge-section" aria-labelledby="paths-title">
    <p class="bridge-eyebrow">{copy.pathsEyebrow}</p>
    <h2 id="paths-title">{copy.pathsTitle}</h2>
    <div class="bridge-paths">
      {copy.paths.map(([title, description, action, href], index) => (
        <a class="bridge-path" href={url(href)}>
          <span class="bridge-path-index">0{index + 1}</span>
          <h3>{title}</h3>
          <p>{description}</p>
          <span class="bridge-path-action">{action}<span aria-hidden="true"> →</span></span>
        </a>
      ))}
    </div>
  </section>

  <section class="bridge-section bridge-method" aria-labelledby="method-title">
    <div>
      <p class="bridge-eyebrow">{copy.methodEyebrow}</p>
      <h2 id="method-title">{copy.methodTitle}</h2>
    </div>
    <ol>
      {copy.method.map(([number, title, description]) => (
        <li><span>{number}</span><div><h3>{title}</h3><p>{description}</p></div></li>
      ))}
    </ol>
  </section>

  <section class="bridge-section" aria-labelledby="principles-title">
    <p class="bridge-eyebrow">{copy.principlesEyebrow}</p>
    <h2 id="principles-title">{copy.principlesTitle}</h2>
    <div class="bridge-principles">
      {copy.principles.map(([letter, title, description]) => (
        <article><span>{letter}</span><h3>{title}</h3><p>{description}</p></article>
      ))}
    </div>
  </section>

  <section class="bridge-final">
    <div><h2>{copy.finalTitle}</h2><p>{copy.finalText}</p></div>
    <a class="bridge-button bridge-button-light" href={url('check/')}>{copy.finalAction}</a>
  </section>
</div>

<script>
  for (const inspector of document.querySelectorAll('[data-inspector]')) {
    const buttons = inspector.querySelectorAll('[data-inspector-mode]');
    const panels = inspector.querySelectorAll('[data-inspector-panel]');

    for (const button of buttons) {
      button.addEventListener('click', () => {
        const mode = button.getAttribute('data-inspector-mode');
        for (const item of buttons) item.setAttribute('aria-pressed', String(item === button));
        for (const panel of panels) {
          panel.classList.toggle('is-active', panel.getAttribute('data-inspector-panel') === mode);
        }
      });
    }
  }
</script>
