---
import BridgeContractGraphic from './BridgeContractGraphic.astro';
import BridgeLayerTree from './BridgeLayerTree.astro';
import PluginMediaShowcase from './PluginMediaShowcase.astro';
import type { LayerNode } from './BridgeLayerTree.astro';

interface Props {
  locale: 'ru' | 'en';
}

const { locale } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/u, '');
const url = (path: string) => `${base}/${locale}/${path.replace(/^\//u, '')}`;
const pluginUrl = 'https://www.figma.com/community/plugin/1654485530503673254/bridge';

const copy = locale === 'ru'
  ? {
      eyebrow: 'Методология передачи макетов',
      title: 'Макет, который не нужно объяснять.',
      lead: 'BRIDGE фиксирует структуру, адаптивы, действия и исключения до начала разработки — прямо там, где принимаются дизайнерские решения.',
      primary: 'Подготовить первый макет',
      secondary: 'Figma plugin BRIDGE',
      newTab: 'откроется в новой вкладке',
      inspectorTitle: 'Сравнение структуры слоёв',
      layersLabel: 'Слои',
      fileLabel: 'Главная · Figma',
      before: 'Без BRIDGE',
      after: 'С BRIDGE',
      beforeNote: 'Названия описывают внешний вид, но не объясняют связи между фреймами.',
      afterNote: 'Та же структура: страница, адаптив, секция и действие читаются прямо из Layers.',
      layerHint: 'Нажмите на имя, чтобы переименовать. Перетащите ручку, чтобы поменять порядок соседних слоёв.',
      layerKeyboardHint: 'На ручке нажмите пробел, меняйте порядок стрелками, подтвердите пробелом или отмените Escape.',
      layerReset: 'Сбросить',
      beforeTree: [
        { id: 'home-final', type: 'frame', name: 'Главная — финал', children: [
          { id: 'frame-42', type: 'frame', name: 'Frame 42', children: [
            { id: 'group-18', type: 'group', name: 'Group 18', children: [
              { id: 'heading', type: 'text', name: 'Heading' },
              { id: 'text', type: 'text', name: 'Text' },
            ] },
            { id: 'button', type: 'component', name: 'Button' },
          ] },
        ] },
        { id: 'home-mobile', type: 'frame', name: 'Главная — mobile', children: [
          { id: 'group-91', type: 'group', name: 'Group 91', children: [
            { id: 'title-mobile', type: 'text', name: 'Title mobile' },
            { id: 'button-copy', type: 'component', name: 'Button copy' },
          ] },
        ] },
      ] satisfies LayerNode[],
      afterTree: [
        { id: 'home', type: 'frame', name: 'Главная', tag: '[page=home]', children: [
          { id: 'desktop', type: 'frame', name: 'Desktop', tag: '[bp=1440] [view=default]', children: [
            { id: 'hero-desktop', type: 'section', name: 'Первый экран', tag: '[section=home-hero]', children: [
              { id: 'hero-copy', type: 'group', name: 'hero-copy', children: [
                { id: 'hero-title', type: 'text', name: 'hero-title' },
              ] },
              { id: 'contact-button', type: 'component', name: 'contact-button', tag: '[action=modal:contact-modal]' },
            ] },
          ] },
          { id: 'mobile', type: 'frame', name: 'Mobile', tag: '[bp=375] [view=default]', children: [
            { id: 'hero-mobile', type: 'section', name: 'Первый экран', tag: '[section=home-hero]' },
          ] },
        ] },
      ] satisfies LayerNode[],
      pathsEyebrow: 'Выберите задачу',
      pathsTitle: 'Начните со своей задачи',
      paths: [
        ['Подготовить макет', 'Проведите первый файл от структуры и адаптивов до проверки по пяти практическим шагам.', 'Открыть быстрый старт', 'start/designer-quick-start/'],
        ['Проверить файл', 'Добавьте связи, откройте карту файла и запустите проверку страницы прямо в Figma.', 'Открыть плагин', 'check/'],
        ['Изучить формат данных', 'Сверьте теги, каталог правил и развивающийся контракт до прототипа интеграции. До версии 1.0 схема может меняться.', 'Открыть статус контракта', 'reference/transfer-contract/'],
        ['Внедрить в команду', 'Запустите пилот на одном рабочем файле, зафиксируйте критерий готовности и добавьте проверку в handoff.', 'Открыть план пилота', 'project/team-adoption/'],
      ],
      methodEyebrow: 'Как это работает',
      methodTitle: 'Три шага к готовому макету',
      method: [
        ['01', 'Соберите техническую правду', 'Фреймы, Auto Layout, компоненты и геометрия остаются в Figma.'],
        ['02', 'Добавьте недостающий смысл', 'Теги описывают страницу, действие, цель, декор, экспорт и исключения.'],
        ['03', 'Проверьте без автора', 'Другой человек должен понять файл без созвона и дополнительных пояснений.'],
      ],
      outcomesEyebrow: 'Что меняется для команды',
      outcomesTitle: 'Передача перестаёт зависеть от памяти автора.',
      outcomesIntro: 'Один и тот же файл отвечает на разные рабочие вопросы — до созвона и до начала реализации.',
      outcomes: [
        ['Дизайнер', 'Видит незаданные адаптивы, действия и цели до передачи макета.'],
        ['Разработчик', 'Переходит из вопроса к точному слою и правилу, а не ищет контекст в переписке.'],
        ['Лид и PM', 'Получает единый критерий готовности и список явно принятых исключений.'],
        ['Студия', 'Сохраняет продуктовые решения в файле, даже когда состав команды меняется.'],
      ],
      principlesEyebrow: 'Шесть принципов',
      principlesTitle: 'Что означает каждая буква BRIDGE',
      principlesIntro: 'BRIDGE — это первые буквы шести английских терминов. Для каждого показаны оригинальное название, русский смысл и вопрос, на который должен отвечать макет.',
      translationLabel: 'По-русски',
      principles: [
        ['B', 'Breakpoints', 'Адаптивы и контрольные ширины', 'Какие ширины и состояния подготовлены?'],
        ['R', 'Roles', 'Назначение слоёв', 'Для чего нужен каждый значимый слой?'],
        ['I', 'Identity', 'Стабильные идентификаторы', 'Как узнать один элемент на разных ширинах?'],
        ['D', 'Dependencies', 'Связи и действия', 'Куда ведут ссылки и что делают кнопки?'],
        ['G', 'Geometry', 'Воспроизводимая геометрия', 'Можно ли повторить размеры, отступы и параметры текста?'],
        ['E', 'Exceptions', 'Осознанные исключения', 'Какие отклонения сделаны намеренно?'],
      ],
      finalTitle: 'Начните с одного рабочего файла.',
      finalText: 'Не нужно переводить весь архив или перестраивать UI Kit. Возьмите одну реальную страницу, передайте её человеку, который не участвовал в дизайне, и проверьте: находит ли он ответы без созвона.',
      finalAction: 'Открыть план пилота',
    }
  : {
      eyebrow: 'Open design handoff methodology',
      title: 'A design that needs no explanation.',
      lead: 'BRIDGE makes structure, breakpoints, actions, and exceptions explicit before implementation — at the point where design decisions are made.',
      primary: 'Prepare your first design',
      secondary: 'Figma plugin BRIDGE',
      newTab: 'opens in a new tab',
      inspectorTitle: 'Layer structure comparison',
      layersLabel: 'Layers',
      fileLabel: 'Home · Figma',
      before: 'Without BRIDGE',
      after: 'With BRIDGE',
      beforeNote: 'Names describe appearance, but not the relationships between frames.',
      afterNote: 'The same structure: page, breakpoint, section, and action are visible in Layers.',
      layerHint: 'Select a name to rename it. Drag the handle to reorder it among sibling layers.',
      layerKeyboardHint: 'On the reorder handle, press Space, move with Arrow keys, press Space to drop, or Escape to cancel.',
      layerReset: 'Reset',
      beforeTree: [
        { id: 'home-final', type: 'frame', name: 'Home — final', children: [
          { id: 'frame-42', type: 'frame', name: 'Frame 42', children: [
            { id: 'group-18', type: 'group', name: 'Group 18', children: [
              { id: 'heading', type: 'text', name: 'Heading' },
              { id: 'text', type: 'text', name: 'Text' },
            ] },
            { id: 'button', type: 'component', name: 'Button' },
          ] },
        ] },
        { id: 'home-mobile', type: 'frame', name: 'Home — mobile', children: [
          { id: 'group-91', type: 'group', name: 'Group 91', children: [
            { id: 'title-mobile', type: 'text', name: 'Title mobile' },
            { id: 'button-copy', type: 'component', name: 'Button copy' },
          ] },
        ] },
      ] satisfies LayerNode[],
      afterTree: [
        { id: 'home', type: 'frame', name: 'Home', tag: '[page=home]', children: [
          { id: 'desktop', type: 'frame', name: 'Desktop', tag: '[bp=1440] [view=default]', children: [
            { id: 'hero-desktop', type: 'section', name: 'Hero', tag: '[section=home-hero]', children: [
              { id: 'hero-copy', type: 'group', name: 'hero-copy', children: [
                { id: 'hero-title', type: 'text', name: 'hero-title' },
              ] },
              { id: 'contact-button', type: 'component', name: 'contact-button', tag: '[action=modal:contact-modal]' },
            ] },
          ] },
          { id: 'mobile', type: 'frame', name: 'Mobile', tag: '[bp=375] [view=default]', children: [
            { id: 'hero-mobile', type: 'section', name: 'Hero', tag: '[section=home-hero]' },
          ] },
        ] },
      ] satisfies LayerNode[],
      pathsEyebrow: 'Choose a task',
      pathsTitle: 'Start with the job in front of you',
      paths: [
        ['Prepare a design', 'Take a first file from structure and breakpoints to review in five practical steps.', 'Open quick start', 'start/designer-quick-start/'],
        ['Review a Figma file', 'Add relationships, open the file map, and run Page Check directly in Figma.', 'Open plugin', 'check/'],
        ['Explore the data format', 'Review the tags, rule catalog, and evolving contract before prototyping an integration. The schema may change before 1.0.', 'Open contract status', 'reference/transfer-contract/'],
        ['Adopt it with a team', 'Pilot BRIDGE on one working file, define readiness, and add the check to your handoff.', 'Open pilot plan', 'project/team-adoption/'],
      ],
      methodEyebrow: 'How it works',
      methodTitle: 'Three steps to a transferable design',
      method: [
        ['01', 'Build technical truth', 'Frames, Auto Layout, components, and geometry remain native Figma data.'],
        ['02', 'Declare missing intent', 'Tags describe pages, actions, targets, decor, assets, and exceptions.'],
        ['03', 'Review without the author', 'Someone else should understand the file without a call or private context.'],
      ],
      outcomesEyebrow: 'What changes for the team',
      outcomesTitle: 'Handoff no longer depends on the author’s memory.',
      outcomesIntro: 'The same file answers each role’s working questions before a call and before implementation starts.',
      outcomes: [
        ['Designer', 'Finds undeclared breakpoints, actions, and targets before handing off the design.'],
        ['Developer', 'Jumps from an issue to the exact layer and rule instead of searching chat history.'],
        ['Lead and PM', 'Gets one definition of ready and a visible list of intentional exceptions.'],
        ['Studio', 'Keeps product decisions in the file even when the people on the project change.'],
      ],
      principlesEyebrow: 'Six principles',
      principlesTitle: 'What every BRIDGE letter means',
      principlesIntro: 'BRIDGE takes its name from six English terms. Each one names a part of the handoff contract and a question the design must answer.',
      translationLabel: '',
      principles: [
        ['B', 'Breakpoints', '', 'Which widths and responsive states exist?'],
        ['R', 'Roles', '', 'What is every important layer for?'],
        ['I', 'Identity', '', 'How is one element recognized across variants?'],
        ['D', 'Dependencies', '', 'Where do links and actions lead?'],
        ['G', 'Geometry', '', 'Can size, spacing, and text metrics be reproduced?'],
        ['E', 'Exceptions', '', 'Which deviations are intentional?'],
      ],
      finalTitle: 'Start with one working file.',
      finalText: 'You do not need to migrate the archive or rebuild the UI kit. Choose one real page, hand it to someone who did not design it, and see whether they can answer the implementation questions without a call.',
      finalAction: 'Open pilot plan',
    };
---

<div class="bridge-home not-content">
  <section class="bridge-hero" aria-labelledby="bridge-home-title">
    <div class="bridge-hero-copy">
      <p class="bridge-eyebrow">{copy.eyebrow}</p>
      <h1 id="bridge-home-title">{copy.title}</h1>
      <p class="bridge-lead">{copy.lead}</p>
      <div class="bridge-actions">
        <a class="bridge-button bridge-button-primary" href={url('start/designer-quick-start/')}>{copy.primary}</a>
        <a class="bridge-button bridge-button-secondary" href={pluginUrl} target="_blank" rel="noopener noreferrer">
          {copy.secondary}<span aria-hidden="true"> ↗</span><span class="sr-only"> — {copy.newTab}</span>
        </a>
      </div>
    </div>

    <div class="bridge-inspector" data-inspector data-locale={locale}>
      <div class="bridge-inspector-bar">
        <strong><span class="bridge-figma-mark" aria-hidden="true">F</span>{copy.layersLabel}</strong>
        <span>{copy.fileLabel}</span>
      </div>
      <div class="bridge-inspector-tabs" role="tablist" aria-label={copy.inspectorTitle}>
        <button id="layers-before-tab" type="button" role="tab" data-inspector-mode="before" aria-selected="false" aria-controls="layers-before-panel" tabindex="-1">{copy.before}</button>
        <button id="layers-after-tab" type="button" role="tab" data-inspector-mode="after" aria-selected="true" aria-controls="layers-after-panel">{copy.after}</button>
      </div>
      <div id="layers-before-panel" class="bridge-layers-panel" role="tabpanel" aria-labelledby="layers-before-tab" data-inspector-panel="before" hidden>
        <div class="bridge-layer-tree" data-layer-tree>
          <p id="layers-before-help" class="sr-only">{copy.layerKeyboardHint}</p>
          <BridgeLayerTree nodes={copy.beforeTree} locale={locale} helpId="layers-before-help" />
          <span class="sr-only" aria-live="polite" data-layer-live></span>
        </div>
        <div class="bridge-layer-footer">
          <div><p>{copy.beforeNote}</p><small><span aria-hidden="true">⠿</span>{copy.layerHint}</small></div>
          <button type="button" data-layer-reset hidden>{copy.layerReset}</button>
        </div>
      </div>
      <div id="layers-after-panel" class="bridge-layers-panel is-active" role="tabpanel" aria-labelledby="layers-after-tab" data-inspector-panel="after">
        <div class="bridge-layer-tree" data-layer-tree>
          <p id="layers-after-help" class="sr-only">{copy.layerKeyboardHint}</p>
          <BridgeLayerTree nodes={copy.afterTree} locale={locale} helpId="layers-after-help" />
          <span class="sr-only" aria-live="polite" data-layer-live></span>
        </div>
        <div class="bridge-layer-footer">
          <div><p>{copy.afterNote}</p><small><span aria-hidden="true">⠿</span>{copy.layerHint}</small></div>
          <button type="button" data-layer-reset hidden>{copy.layerReset}</button>
        </div>
      </div>
    </div>
  </section>

  <section class="bridge-section" aria-labelledby="paths-title">
    <p class="bridge-eyebrow">{copy.pathsEyebrow}</p>
    <h2 id="paths-title">{copy.pathsTitle}</h2>
    <div class="bridge-paths">
      {copy.paths.map(([title, description, action, href]) => (
        <a class="bridge-path" href={url(href)}>
          <h3>{title}</h3>
          <p>{description}</p>
          <span class="bridge-path-action">{action}<span aria-hidden="true"> →</span></span>
        </a>
      ))}
    </div>
  </section>

  <BridgeContractGraphic locale={locale} />

  <section class="bridge-section bridge-method" aria-labelledby="method-title">
    <div>
      <p class="bridge-eyebrow">{copy.methodEyebrow}</p>
      <h2 id="method-title">{copy.methodTitle}</h2>
    </div>
    <ol>
      {copy.method.map(([number, title, description]) => (
        <li><span>{number}</span><div><h3>{title}</h3><p>{description}</p></div></li>
      ))}
    </ol>
  </section>

  <PluginMediaShowcase locale={locale} compact />

  <section class="bridge-section bridge-outcomes" aria-labelledby="outcomes-title">
    <header>
      <p class="bridge-eyebrow">{copy.outcomesEyebrow}</p>
      <h2 id="outcomes-title">{copy.outcomesTitle}</h2>
      <p>{copy.outcomesIntro}</p>
    </header>
    <div>
      {copy.outcomes.map(([role, outcome]) => (
        <article><h3>{role}</h3><p>{outcome}</p></article>
      ))}
    </div>
  </section>

  <section class="bridge-section" aria-labelledby="principles-title">
    <p class="bridge-eyebrow">{copy.principlesEyebrow}</p>
    <h2 id="principles-title">{copy.principlesTitle}</h2>
    <p class="bridge-principles-intro">{copy.principlesIntro}</p>
    <div class="bridge-principles">
      {copy.principles.map(([letter, english, translation, description]) => (
        <article>
          <span>{letter}</span>
          <div class="bridge-principle-copy">
            <h3>
              <span lang="en">{english}</span>
              {translation && <small><em>{copy.translationLabel}:</em> {translation}</small>}
            </h3>
            <p>{description}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="bridge-final" id="bridge-final">
    <div><h2>{copy.finalTitle}</h2><p>{copy.finalText}</p></div>
    <a class="bridge-button bridge-button-primary" href={url('project/team-adoption/')}>{copy.finalAction}</a>
  </section>
</div>

<script>
  type PointerDrag = {
    item: HTMLElement;
    list: HTMLOListElement;
    tree: HTMLElement;
    handle: HTMLButtonElement;
    pointerId: number;
    startX: number;
    startY: number;
    offsetY: number;
    active: boolean;
    ghost: HTMLElement | null;
    target: HTMLElement | null;
    before: boolean;
  };

  type KeyboardGrab = {
    item: HTMLElement;
    list: HTMLOListElement;
    tree: HTMLElement;
    handle: HTMLButtonElement;
    originalNext: Element | null;
    moved: boolean;
  };

  const directItems = (list: HTMLOListElement) => [...list.children].filter(
    (child): child is HTMLElement => child instanceof HTMLElement && child.hasAttribute('data-layer-item'),
  );

  const initInspectors = () => {
    for (const staleGhost of document.querySelectorAll('.bridge-layer-ghost')) staleGhost.remove();

    for (const inspector of document.querySelectorAll<HTMLElement>('[data-inspector]')) {
      if (inspector.dataset.inspectorReady === 'true') continue;
      inspector.dataset.inspectorReady = 'true';

      const locale = inspector.dataset.locale === 'en' ? 'en' : 'ru';
      const messages = locale === 'ru'
        ? {
            rename: (name: string) => `Переименовать слой «${name}»`,
            input: (name: string) => `Новое название слоя «${name}»`,
            reorder: (name: string, position: number, total: number) => `Изменить порядок слоя «${name}». Позиция ${position} из ${total}`,
            renamed: (before: string, after: string) => `Слой переименован: «${before}» → «${after}».`,
            empty: 'Введите название слоя.',
            emptyRestored: 'Пустое название не сохранено. Сохранено прежнее название слоя.',
            picked: (name: string) => `Слой «${name}» выбран. Меняйте порядок стрелками, подтвердите пробелом или отмените Escape.`,
            position: (name: string, position: number, total: number) => `Слой «${name}»: позиция ${position} из ${total}.`,
            cancelled: (name: string) => `Изменение порядка слоя «${name}» отменено.`,
            reset: 'Исходный порядок и названия восстановлены.',
          }
        : {
            rename: (name: string) => `Rename layer “${name}”`,
            input: (name: string) => `New name for layer “${name}”`,
            reorder: (name: string, position: number, total: number) => `Reorder layer “${name}”. Position ${position} of ${total}`,
            renamed: (before: string, after: string) => `Layer renamed: “${before}” → “${after}”.`,
            empty: 'Enter a layer name.',
            emptyRestored: 'The empty name was not saved. The previous layer name was kept.',
            picked: (name: string) => `Layer “${name}” selected. Use the arrow keys to move it, press Space to drop, or Escape to cancel.`,
            position: (name: string, position: number, total: number) => `Layer “${name}”: position ${position} of ${total}.`,
            cancelled: (name: string) => `Reordering layer “${name}” was cancelled.`,
            reset: 'The original order and names have been restored.',
          };

      const buttons = [...inspector.querySelectorAll<HTMLButtonElement>('[data-inspector-mode]')];
      const panels = [...inspector.querySelectorAll<HTMLElement>('[data-inspector-panel]')];
      let pointerDrag: PointerDrag | null = null;
      let keyboardGrab: KeyboardGrab | null = null;

      const layerName = (item: HTMLElement) => item.querySelector<HTMLButtonElement>('[data-layer-rename]')?.textContent?.trim() || '';

      const announce = (tree: HTMLElement, message: string) => {
        const live = tree.querySelector<HTMLElement>('[data-layer-live]');
        if (!live) return;
        live.textContent = '';
        window.setTimeout(() => { live.textContent = message; }, 10);
      };

      const updateLabels = (tree: HTMLElement) => {
        for (const list of tree.querySelectorAll<HTMLOListElement>('.bridge-layer-list')) {
          const items = directItems(list);
          items.forEach((item, index) => {
            const name = layerName(item);
            const rename = item.querySelector<HTMLButtonElement>(':scope > .bridge-layer-row [data-layer-rename]');
            const input = item.querySelector<HTMLInputElement>(':scope > .bridge-layer-row [data-layer-input]');
            const handle = item.querySelector<HTMLButtonElement>(':scope > .bridge-layer-row [data-layer-handle]');
            rename?.setAttribute('aria-label', messages.rename(name));
            input?.setAttribute('aria-label', messages.input(name));
            if (handle) {
              handle.disabled = items.length < 2;
              handle.setAttribute('aria-label', messages.reorder(name, index + 1, items.length));
            }
          });
        }
      };

      const markDirty = (tree: HTMLElement) => {
        tree.dataset.layerDirty = 'true';
        const reset = tree.closest('[data-inspector-panel]')?.querySelector<HTMLButtonElement>('[data-layer-reset]');
        if (reset) reset.hidden = false;
      };

      const clearDropMarker = (list: HTMLOListElement) => {
        for (const item of directItems(list)) item.classList.remove('is-drop-before', 'is-drop-after');
      };

      const cleanPointerDrag = () => {
        if (!pointerDrag) return;
        clearDropMarker(pointerDrag.list);
        pointerDrag.item.classList.remove('is-dragging');
        pointerDrag.handle.setAttribute('aria-pressed', 'false');
        pointerDrag.ghost?.remove();
        if (pointerDrag.handle.hasPointerCapture(pointerDrag.pointerId)) {
          pointerDrag.handle.releasePointerCapture(pointerDrag.pointerId);
        }
        pointerDrag = null;
      };

      const finishKeyboardGrab = (commit: boolean) => {
        if (!keyboardGrab) return;
        const state = keyboardGrab;
        const name = layerName(state.item);
        if (!commit && state.moved) state.list.insertBefore(state.item, state.originalNext);
        state.item.classList.remove('is-keyboard-dragging');
        state.handle.setAttribute('aria-pressed', 'false');
        updateLabels(state.tree);
        const siblings = directItems(state.list);
        const position = siblings.indexOf(state.item) + 1;
        if (commit && state.moved) {
          markDirty(state.tree);
          announce(state.tree, messages.position(name, position, siblings.length));
        } else if (!commit) {
          announce(state.tree, messages.cancelled(name));
        }
        keyboardGrab = null;
        state.handle.focus();
      };

      const openEditor = (button: HTMLButtonElement) => {
        const item = button.closest<HTMLElement>('[data-layer-item]');
        const tree = button.closest<HTMLElement>('[data-layer-tree]');
        const input = item?.querySelector<HTMLInputElement>(':scope > .bridge-layer-row [data-layer-input]');
        if (!item || !tree || !input || item.classList.contains('is-editing')) return;
        if (keyboardGrab) finishKeyboardGrab(true);
        item.classList.add('is-editing');
        input.value = button.textContent?.trim() || '';
        button.hidden = true;
        input.hidden = false;
        input.focus();
        input.select();
      };

      const closeEditor = (input: HTMLInputElement, cancel = false, restoreFocus = false) => {
        const item = input.closest<HTMLElement>('[data-layer-item]');
        const tree = input.closest<HTMLElement>('[data-layer-tree]');
        const button = item?.querySelector<HTMLButtonElement>(':scope > .bridge-layer-row [data-layer-rename]');
        if (!item || !tree || !button || !item.classList.contains('is-editing')) return;
        const before = button.textContent?.trim() || '';
        const candidate = input.value.trim();
        if (!cancel && !candidate && restoreFocus) {
          announce(tree, messages.empty);
          input.focus();
          input.select();
          return;
        }
        const after = cancel || !candidate ? before : candidate;
        if (!cancel && !candidate) announce(tree, messages.emptyRestored);
        if (after !== before) {
          button.textContent = after;
          input.value = after;
          input.setAttribute('value', after);
          markDirty(tree);
          announce(tree, messages.renamed(before, after));
        } else {
          input.value = before;
        }
        item.classList.remove('is-editing');
        input.hidden = true;
        button.hidden = false;
        updateLabels(tree);
        if (restoreFocus) button.focus();
      };

      for (const panel of panels) {
        const tree = panel.querySelector<HTMLElement>('[data-layer-tree]');
        const rootList = tree?.querySelector<HTMLOListElement>(':scope > .bridge-layer-list');
        const reset = panel.querySelector<HTMLButtonElement>('[data-layer-reset]');
        if (!tree || !rootList || !reset) continue;
        const initialMarkup = rootList.innerHTML;
        updateLabels(tree);

        tree.addEventListener('click', (event) => {
          if (!(event.target instanceof Element)) return;
          const rename = event.target.closest<HTMLButtonElement>('[data-layer-rename]');
          if (rename) openEditor(rename);
        });

        tree.addEventListener('focusout', (event) => {
          if (!(event.target instanceof HTMLInputElement) || !event.target.matches('[data-layer-input]')) return;
          closeEditor(event.target);
        });

        tree.addEventListener('keydown', (event) => {
          if (!(event.target instanceof Element)) return;
          const input = event.target.closest<HTMLInputElement>('[data-layer-input]');
          if (input) {
            if (event.isComposing) return;
            if (event.key === 'Enter') {
              event.preventDefault();
              closeEditor(input, false, true);
            } else if (event.key === 'Escape') {
              event.preventDefault();
              closeEditor(input, true, true);
            }
            return;
          }

          const rename = event.target.closest<HTMLButtonElement>('[data-layer-rename]');
          if (rename && event.key === 'F2') {
            event.preventDefault();
            openEditor(rename);
            return;
          }

          const handle = event.target.closest<HTMLButtonElement>('[data-layer-handle]');
          if (!handle || handle.disabled) return;
          const item = handle.closest<HTMLElement>('[data-layer-item]');
          const list = item?.parentElement;
          if (!item || !(list instanceof HTMLOListElement)) return;

          if (event.key === ' ' || event.key === 'Enter') {
            event.preventDefault();
            if (keyboardGrab?.handle === handle) {
              finishKeyboardGrab(true);
            } else {
              if (keyboardGrab) finishKeyboardGrab(true);
              keyboardGrab = { item, list, tree, handle, originalNext: item.nextElementSibling, moved: false };
              item.classList.add('is-keyboard-dragging');
              handle.setAttribute('aria-pressed', 'true');
              announce(tree, messages.picked(layerName(item)));
            }
            return;
          }

          if (keyboardGrab?.handle !== handle) return;
          if (event.key === 'Escape') {
            event.preventDefault();
            finishKeyboardGrab(false);
            return;
          }
          if (!['ArrowUp', 'ArrowDown', 'Home', 'End'].includes(event.key)) return;
          event.preventDefault();
          const first = directItems(list)[0];
          const last = directItems(list).at(-1);
          let moved = false;
          if (event.key === 'ArrowUp' && item.previousElementSibling) {
            list.insertBefore(item, item.previousElementSibling);
            moved = true;
          } else if (event.key === 'ArrowDown' && item.nextElementSibling) {
            list.insertBefore(item.nextElementSibling, item);
            moved = true;
          } else if (event.key === 'Home' && first && first !== item) {
            list.insertBefore(item, first);
            moved = true;
          } else if (event.key === 'End' && last && last !== item) {
            list.append(item);
            moved = true;
          }
          if (moved && keyboardGrab) {
            keyboardGrab.moved = true;
            updateLabels(tree);
            const siblings = directItems(list);
            announce(tree, messages.position(layerName(item), siblings.indexOf(item) + 1, siblings.length));
            handle.focus();
          }
        });

        tree.addEventListener('pointerdown', (event) => {
          if (!(event.target instanceof Element) || (event.pointerType === 'mouse' && event.button !== 0)) return;
          const handle = event.target.closest<HTMLButtonElement>('[data-layer-handle]');
          if (!handle || handle.disabled) return;
          const item = handle.closest<HTMLElement>('[data-layer-item]');
          const list = item?.parentElement;
          const row = item?.querySelector<HTMLElement>(':scope > .bridge-layer-row');
          if (!item || !(list instanceof HTMLOListElement) || !row) return;
          if (keyboardGrab) finishKeyboardGrab(true);
          cleanPointerDrag();
          const rect = row.getBoundingClientRect();
          pointerDrag = {
            item,
            list,
            tree,
            handle,
            pointerId: event.pointerId,
            startX: event.clientX,
            startY: event.clientY,
            offsetY: event.clientY - rect.top,
            active: false,
            ghost: null,
            target: null,
            before: true,
          };
          handle.setPointerCapture(event.pointerId);
          event.preventDefault();
        });

        tree.addEventListener('pointermove', (event) => {
          if (!pointerDrag || event.pointerId !== pointerDrag.pointerId) return;
          const distance = Math.hypot(event.clientX - pointerDrag.startX, event.clientY - pointerDrag.startY);
          if (!pointerDrag.active && distance < 6) return;
          if (!pointerDrag.active) {
            const row = pointerDrag.item.querySelector<HTMLElement>(':scope > .bridge-layer-row');
            if (!row) return;
            const rect = row.getBoundingClientRect();
            const ghost = row.cloneNode(true) as HTMLElement;
            ghost.className = 'bridge-layer-ghost';
            ghost.style.width = `${rect.width}px`;
            ghost.style.left = `${rect.left}px`;
            ghost.style.top = `${event.clientY - pointerDrag.offsetY}px`;
            for (const control of ghost.querySelectorAll<HTMLElement>('button, input')) control.tabIndex = -1;
            document.body.append(ghost);
            pointerDrag.ghost = ghost;
            pointerDrag.active = true;
            pointerDrag.item.classList.add('is-dragging');
            pointerDrag.handle.setAttribute('aria-pressed', 'true');
          }
          event.preventDefault();
          if (pointerDrag.ghost) pointerDrag.ghost.style.top = `${event.clientY - pointerDrag.offsetY}px`;
          clearDropMarker(pointerDrag.list);
          const siblings = directItems(pointerDrag.list).filter((item) => item !== pointerDrag?.item);
          if (!siblings.length) return;
          let target = siblings.at(-1) || null;
          let before = false;
          for (const sibling of siblings) {
            const rect = sibling.querySelector<HTMLElement>(':scope > .bridge-layer-row')?.getBoundingClientRect();
            if (rect && event.clientY < rect.top + rect.height / 2) {
              target = sibling;
              before = true;
              break;
            }
          }
          pointerDrag.target = target;
          pointerDrag.before = before;
          target?.classList.add(before ? 'is-drop-before' : 'is-drop-after');
        });

        const finishPointer = (event: PointerEvent, commit: boolean) => {
          if (!pointerDrag || event.pointerId !== pointerDrag.pointerId) return;
          const state = pointerDrag;
          if (commit && state.active && state.target) {
            const previousIndex = directItems(state.list).indexOf(state.item);
            let reference: Element | null = state.before ? state.target : state.target.nextElementSibling;
            if (reference === state.item) reference = state.item.nextElementSibling;
            state.list.insertBefore(state.item, reference);
            updateLabels(state.tree);
            const siblings = directItems(state.list);
            const nextIndex = siblings.indexOf(state.item);
            if (nextIndex !== previousIndex) {
              markDirty(state.tree);
              announce(state.tree, messages.position(layerName(state.item), nextIndex + 1, siblings.length));
            }
          }
          cleanPointerDrag();
        };

        tree.addEventListener('pointerup', (event) => finishPointer(event, true));
        tree.addEventListener('pointercancel', (event) => finishPointer(event, false));

        reset.addEventListener('click', () => {
          if (pointerDrag?.tree === tree) cleanPointerDrag();
          if (keyboardGrab?.tree === tree) finishKeyboardGrab(false);
          rootList.innerHTML = initialMarkup;
          tree.dataset.layerDirty = 'false';
          reset.hidden = true;
          updateLabels(tree);
          announce(tree, messages.reset);
        });
      }

      const activate = (button: HTMLButtonElement) => {
        cleanPointerDrag();
        if (keyboardGrab) finishKeyboardGrab(true);
        const mode = button.dataset.inspectorMode;
        for (const item of buttons) {
          const active = item === button;
          item.setAttribute('aria-selected', String(active));
          item.tabIndex = active ? 0 : -1;
        }
        for (const panel of panels) {
          const active = panel.dataset.inspectorPanel === mode;
          panel.hidden = !active;
          panel.classList.toggle('is-active', active);
        }
      };

      for (const button of buttons) {
        button.addEventListener('click', () => activate(button));
        button.addEventListener('keydown', (event) => {
          if (!['ArrowLeft', 'ArrowRight', 'Home', 'End'].includes(event.key)) return;
          event.preventDefault();
          let index = buttons.indexOf(button);
          if (event.key === 'Home') index = 0;
          else if (event.key === 'End') index = buttons.length - 1;
          else index = (index + (event.key === 'ArrowRight' ? 1 : -1) + buttons.length) % buttons.length;
          const next = buttons[index];
          if (next) {
            activate(next);
            next.focus();
          }
        });
      }
    }
  };

  initInspectors();
  document.addEventListener('astro:page-load', initInspectors);
</script>
