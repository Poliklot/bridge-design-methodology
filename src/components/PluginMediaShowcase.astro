        },
      },
    };

const allSlides = [
  { id: 'preflight', desktop: '01-preflight.png', mobile: 'ui/preflight.png', mobileWidth: 680, mobileHeight: 760 },
  { id: 'intent', desktop: '02-tagging.png', mobile: 'ui/tagging.png', mobileWidth: 560, mobileHeight: 640 },
  { id: 'targets', desktop: '03-clipboard.png', mobile: 'ui/clipboard.png', mobileWidth: 560, mobileHeight: 640 },
  { id: 'map', desktop: '04-file-map.png', mobile: 'ui/navigator.png', mobileWidth: 560, mobileHeight: 640 },
  { id: 'responsive', desktop: '05-responsive.png', mobile: 'ui/preflight-ready.png', mobileWidth: 680, mobileHeight: 760 },
  { id: 'layer', desktop: '06-direct-navigation.png', mobile: 'ui/preflight-details.png', mobileWidth: 680, mobileHeight: 760 },
  { id: 'rule', desktop: '07-rules-and-help.png', mobile: 'ui/rules.png', mobileWidth: 1312, mobileHeight: 720 },
] as const;

const compactIds = new Set(['intent', 'targets', 'preflight']);
const slides = allSlides
  .filter((slide) => !compact || compactIds.has(slide.id))
  .map((slide) => ({ ...slide, ...copy.slides[slide.id] }));
const mode = compact ? 'home' : 'plugin';
const heading = copy[mode];
---

<section class:list={['bridge-section', 'plugin-showcase', { 'is-compact': compact }]} aria-labelledby={`${mode}-showcase-title`}>
  <header class="plugin-showcase-heading">
    <p class="bridge-eyebrow">{heading.eyebrow}</p>
    <div>
      <h2 id={`${mode}-showcase-title`}>{heading.title}</h2>
      <p>{heading.lead}</p>
    </div>
  </header>

  <div class="plugin-showcase-shell" data-plugin-showcase>
    <div class="plugin-showcase-mobile-nav" aria-label={copy.tabsLabel}>
      <button type="button" data-showcase-previous aria-label={copy.previous}><span aria-hidden="true">←</span>{copy.previous}</button>
      <span>{copy.screen} <strong data-showcase-mobile-count>1</strong> {copy.of} {slides.length}</span>
      <button type="button" data-showcase-next aria-label={copy.next}>{copy.next}<span aria-hidden="true">→</span></button>
    </div>
    <div class="plugin-showcase-tabs" role="tablist" aria-label={copy.tabsLabel}>
      {slides.map((slide, index) => (
        <button
          id={`${mode}-showcase-${slide.id}-tab`}
          type="button"
          role="tab"
          aria-selected={index === 0 ? 'true' : 'false'}
          aria-controls={`${mode}-showcase-${slide.id}-panel`}
          tabindex={index === 0 ? '0' : '-1'}
          data-showcase-tab
          data-showcase-index={index}
        >
          <span>{String(index + 1).padStart(2, '0')}</span>
          <strong>{slide.title}</strong>
          <small>{slide.label}</small>
        </button>
      ))}
    </div>

    <div class="plugin-showcase-stage">
      <div class="plugin-showcase-stage-bar">
        <span><i aria-hidden="true"></i>{heading.stageLabel}</span>
      </div>
      {slides.map((slide, index) => (
        <figure
          id={`${mode}-showcase-${slide.id}-panel`}
          role="tabpanel"
          aria-labelledby={`${mode}-showcase-${slide.id}-tab`}
          tabindex="0"
          data-showcase-panel
          data-showcase-index={index}
          hidden={index !== 0}
        >
          <picture>
            <source
              media="(max-width: 60rem)"
              srcset={asset(slide.mobile)}
              width={locale === 'ru' ? 900 : slide.mobileWidth}
              height={locale === 'ru' ? 1200 : slide.mobileHeight}
            />
            <img
              src={asset(slide.desktop)}
              width="1920"
              height="1080"
              alt={slide.alt}
              loading="lazy"
              decoding="async"
            />
          </picture>
          <figcaption>
            <div><span>{slide.label}</span><strong>{slide.title}</strong></div>
            <p>{slide.description}</p>
            <code>{slide.evidence}</code>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>

  {compact && (
    <div class="plugin-showcase-action">
      <a href={pluginUrl} target="_blank" rel="noopener noreferrer">
        {heading.action}<span aria-hidden="true"> ↗</span><span class="sr-only"> — {copy.newTab}</span>
      </a>
    </div>
  )}
</section>

<script>
  for (const root of document.querySelectorAll<HTMLElement>('[data-plugin-showcase]')) {
    const tabs = [...root.querySelectorAll<HTMLButtonElement>('[data-showcase-tab]')];
    const panels = [...root.querySelectorAll<HTMLElement>('[data-showcase-panel]')];
    const mobileCount = root.querySelector<HTMLElement>('[data-showcase-mobile-count]');
    const previous = root.querySelector<HTMLButtonElement>('[data-showcase-previous]');
    const next = root.querySelector<HTMLButtonElement>('[data-showcase-next]');

    const activate = (tab: HTMLButtonElement, moveFocus = false, revealTab = false) => {
      const index = Number(tab.dataset.showcaseIndex || 0);
      for (const item of tabs) {
        const active = item === tab;
        item.setAttribute('aria-selected', String(active));
        item.tabIndex = active ? 0 : -1;
      }
      for (const panel of panels) panel.hidden = Number(panel.dataset.showcaseIndex || 0) !== index;
      if (mobileCount) mobileCount.textContent = String(index + 1);
      if (revealTab) tab.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
      if (moveFocus) tab.focus();
    };

    for (const tab of tabs) {
      tab.addEventListener('click', () => activate(tab, false, true));
      tab.addEventListener('keydown', (event) => {
        const current = tabs.indexOf(tab);
        let next = -1;
        if (event.key === 'ArrowRight' || event.key === 'ArrowDown') next = (current + 1) % tabs.length;
        if (event.key === 'ArrowLeft' || event.key === 'ArrowUp') next = (current - 1 + tabs.length) % tabs.length;
        if (event.key === 'Home') next = 0;
        if (event.key === 'End') next = tabs.length - 1;
        if (next < 0) return;
        event.preventDefault();
        const nextTab = tabs[next];
        if (nextTab) activate(nextTab, true, true);
      });
    }

    const move = (direction: number) => {
      const current = Math.max(0, tabs.findIndex((tab) => tab.getAttribute('aria-selected') === 'true'));
      const target = tabs[(current + direction + tabs.length) % tabs.length];
      if (target) activate(target, false, true);
    };

    previous?.addEventListener('click', () => move(-1));
    next?.addEventListener('click', () => move(1));
  }
</script>
